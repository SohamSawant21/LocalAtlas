generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum District {
  SINDHUDURG
  RATNAGIRI
  RAIGAD
}

enum LocationCategory {
  BEACH
  WATERFALL
  FORT
  TEMPLE
  TRAIL
  VIEWPOINT
  EATERY
  HERITAGE
  HOMESTAY
  OTHER
}

enum CrowdLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum Difficulty {
  EASY
  MODERATE
  HARD
  EXPERT
}

enum RoadCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  OFFROAD
}

enum Season {
  MONSOON
  WINTER
  SUMMER
  ALL_YEAR
}

enum LocationStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  VERIFICATION
  APPROVAL
  WEATHER_ALERT
  ROAD_CLOSURE
  ACHIEVEMENT
  SYSTEM
}

enum PostCategory {
  PLACE_RECOMMENDATION
  QUESTION
  PHOTO
  TRAVEL_TIP
  ALERT
  FESTIVAL
  ROUTE_UPDATE
  FOOD
  HERITAGE
  MEETUP
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  password       String?
  avatar         String?
  bio            String?
  location       String?
  role           UserRole  @default(USER)
  emailVerified  DateTime?
  reputation     Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Moderation
  isBanned       Boolean   @default(false)
  isShadowbanned Boolean   @default(false)
  suspendedUntil DateTime?

  // Settings
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(false)
  locationTracking   Boolean  @default(true)
  publicProfile      Boolean  @default(true)

  accounts       Account[]
  sessions       Session[]
  locations      Location[]    @relation("contributor")
  photos         Photo[]
  savedPlaces    SavedPlace[]
  savedPosts     SavedPost[]
  trips          Trip[]
  reviews        Review[]
  stories        Story[]
  comments       Comment[]
  likes          Like[]
  communityPosts CommunityPost[]
  notifications  Notification[] @relation("notificationRecipient")
  actedNotifications Notification[] @relation("notificationActor")
  achievements   Achievement[]
  userBadges     UserBadge[]
  verifications  Verification[]
  pollVotes      PollVote[]
  followers      Follow[]  @relation("following")
  following      Follow[]  @relation("follower")
  reports        Report[]  @relation("reportReporter")
  moderatorLogs  ModeratorActionLog[] @relation("moderatorAction")

  @@index([reputation])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Location {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String           @db.Text
  district          District
  category          LocationCategory
  latitude          Float
  longitude         Float
  hiddenScore       Float            @default(0)
  crowdLevel        CrowdLevel       @default(LOW)
  difficulty        Difficulty       @default(EASY)
  roadCondition     RoadCondition    @default(GOOD)
  bestSeason        Season           @default(ALL_YEAR)
  entryFee          String?
  parking           String?
  network           String?
  accessibility     String?
  bestTime          String?
  sunset            String?
  safety            String?
  verified          Boolean          @default(false)
  verificationCount Int              @default(0)
  status            LocationStatus   @default(DRAFT)
  tags              String[]
  images            String[]
  userId            String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  contributor   User            @relation("contributor", fields: [userId], references: [id])
  photos        Photo[]
  savedBy       SavedPlace[]
  tripLocations TripLocation[]
  reviews       Review[]
  stories       Story[]
  comments      Comment[]
  likes         Like[]
  notifications Notification[]
  verifications Verification[]
  communityPosts CommunityPost[]

  @@index([district])
  @@index([category])
  @@index([status])
  @@index([verified])
  @@index([hiddenScore])
  @@index([userId])
  @@map("locations")
}

model Photo {
  id         String   @id @default(cuid())
  url        String
  caption    String?
  locationId String
  userId     String
  createdAt  DateTime @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("photos")
}

model SavedPlace {
  id             String   @id @default(cuid())
  userId         String
  locationId     String
  collectionName String?
  createdAt      DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("saved_places")
}

model Trip {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations TripLocation[]

  @@index([userId, updatedAt])
  @@map("trips")
}

model TripLocation {
  id         String  @id @default(cuid())
  tripId     String
  locationId String
  order      Int
  notes      String?

  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id])

  @@map("trip_locations")
}

model Review {
  id         String   @id @default(cuid())
  content    String   @db.Text
  rating     Int
  locationId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, locationId])
  @@index([createdAt])
  @@index([locationId])
  @@map("reviews")
}

model Story {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  coverImage String?
  locationId String?
  userId     String
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location? @relation(fields: [locationId], references: [id])
  user     User      @relation(fields: [userId], references: [id])
  likes    Like[]

  @@index([published, createdAt])
  @@index([userId])
  @@map("stories")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Notification {
  id         String           @id @default(cuid())
  type       NotificationType
  title      String
  message    String
  read       Boolean          @default(false)
  userId     String
  actorId    String?
  locationId String?
  createdAt  DateTime         @default(now())

  user     User      @relation("notificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor    User?     @relation("notificationActor", fields: [actorId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([userId, read])
  @@map("notifications")
}

model Achievement {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  criteria    String
  userId      String
  unlockedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  category    String

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @db.Text
  locationId String?
  postId     String?
  userId     String
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location?  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  post     CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
  likes    Like[]

  @@map("comments")
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  locationId String?
  commentId  String?
  storyId    String?
  postId     String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id])
  story    Story?    @relation(fields: [storyId], references: [id])
  post     CommunityPost? @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("likes")
}

model CommunityPost {
  id         String       @id @default(cuid())
  title      String
  content    String       @db.Text
  imageUrls  String[]
  category   PostCategory @default(QUESTION)
  userId     String
  locationId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  comments   Comment[]
  likes      Like[]
  savedBy    SavedPost[]
  poll       Poll?

  @@index([createdAt])
  @@index([userId])
  @@index([category])
  @@index([locationId])
  @@map("community_posts")
}

model SavedPost {
  id             String   @id @default(cuid())
  userId         String
  postId         String
  collectionName String?
  createdAt      DateTime @default(now())
  
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
  @@map("saved_posts")
}

model Poll {
  id        String       @id @default(cuid())
  postId    String       @unique
  options   PollOption[]
  votes     PollVote[]
  createdAt DateTime     @default(now())

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  text      String
  pollId    String
  votes     PollVote[]
  
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  userId    String
  optionId  String
  pollId    String
  createdAt DateTime   @default(now())
  
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  
  @@unique([userId, pollId])
  @@map("poll_votes")
}

model Verification {
  id         String             @id @default(cuid())
  locationId String
  userId     String
  status     VerificationStatus @default(PENDING)
  notes      String?
  createdAt  DateTime           @default(now())

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, locationId])
  @@map("verifications")
}

enum ReportType {
  POST
  COMMENT
  REVIEW
  STORY
  LOCATION
  USER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  type        ReportType
  reason      String       @db.Text
  status      ReportStatus @default(PENDING)
  targetId    String
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter    User         @relation("reportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([targetId])
  @@map("reports")
}

model ModeratorActionLog {
  id          String   @id @default(cuid())
  moderatorId String
  action      String
  targetId    String?
  targetType  String?
  details     String?  @db.Text
  createdAt   DateTime @default(now())

  moderator   User     @relation("moderatorAction", fields: [moderatorId], references: [id], onDelete: Cascade)
  
  @@index([moderatorId, createdAt])
  @@map("moderator_action_logs")
}
